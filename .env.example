# ============================================
# AtlasAI Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Database
DATABASE_URL=postgresql://atlasai:atlasai_password@localhost:5432/atlasai?schema=public

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OpenAI (optional - app works without it using mock mode)
OPENAI_API_KEY=

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
