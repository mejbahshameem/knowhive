// AtlasAI Database Schema
// ========================
// This is the single source of truth for the database structure.
// Run `npx prisma migrate dev` to apply changes.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ========================
// User — anyone who registers on the platform
// ========================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // bcrypt hash, never store plain text
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // table name in PostgreSQL
}
